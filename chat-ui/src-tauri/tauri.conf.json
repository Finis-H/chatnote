{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vault OS",
  "version": "0.1.0",
  "identifier": "com.vault-os.core",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
    "title": "Vault OS",
    "width": 1200,
    "height": 700,
    "minWidth": 400,
    "minHeight": 250,
    "center": true,
    "decorations": false,
    "transparent": true,
    "alwaysOnTop": false,
    "resizable": true
  }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/vault_engine"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
